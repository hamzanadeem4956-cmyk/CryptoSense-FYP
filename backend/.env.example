# Server
PORT=5000

# MongoDB Atlas
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/cryptosence?retryWrites=true&w=majority

# JWT
JWT_SECRET=change_me_to_a_long_random_string

# Frontend URL
FRONTEND_URL=http://localhost:5173

# SendGrid SMTP (user must be literal "apikey"; pass is SG.xxx API key)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=SG.xxxxxxxx
EMAIL_FROM="CryptoSence <verified-sender@example.com>"

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PRICE_ID=price_xxxxxxxx

# Seed admin
ADMIN_EMAIL=admin@cryptosence.com
ADMIN_PASSWORD=Admin12345
